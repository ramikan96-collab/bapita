# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=your_random_string
META_APP_SECRET=from_meta_app_dashboard

# Anthropic (Claude Haiku for AI replies)
ANTHROPIC_API_KEY=from_console.anthropic.com

# Cron security (shared between GitHub Actions and Supabase edge functions)
CRON_SECRET=your_random_string

# Supabase (auto-set in edge functions, add to GitHub secrets for cron)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=auto_set_in_edge_functions_never_expose_to_frontend
